{
  "name": "uniqueiit-research-center",
  "version": "1.0.0",
  "description": "Backend API server for uniqueIIT Research Center",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "node src/scripts/seedData.js",
    "seed:categories": "node src/scripts/seedCategories.js",
    "seed:users": "node src/scripts/createAdmin.js",
    "seed:admin": "node src/modules/auth/scripts/createAdmin.js",
    "seed:blogs": "node src/modules/blogs/scripts/seedBlogsFromJSON.js",
    "seed:blogs:more": "node src/modules/blogs/scripts/seedBlogs.js",
    "seed:treatments": "node src/modules/treatment/scripts/seedTreatments.js",
    "test:blogs": "node src/modules/blogs/scripts/testBlogAPI.js",
    "test:blogs:quick": "node src/modules/blogs/scripts/quickTest.js",
    "migrate": "node src/scripts/migrateData.js",
    "backup": "node src/scripts/backup.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "api",
    "healthcare",
    "mental-health",
    "medical-practice",
    "psychiatrist"
  ],
  "author": "Dr. Syed M Quadri",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "formdata-node": "^6.0.3",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "redis": "^4.6.10",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/uniqueiit-research-center.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/uniqueiit-research-center/issues"
  },
  "homepage": "https://github.com/your-username/uniqueiit-research-center#readme"
}
